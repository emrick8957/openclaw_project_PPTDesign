{
  "$schema": "https://example.local/huawei/page_render_spec.schema.v0.1.json",
  "schema_name": "page_render_spec",
  "schema_version": "0.1",
  "positioning": "A-to-C complex-page construction constraint layer; not a content source; not a mandatory full-chain deliverable.",
  "required_top_level_fields": [
    "schema_version",
    "deck_id",
    "slide_no",
    "spec_level",
    "source_trace",
    "derived_contract",
    "render_units",
    "text_fit_policy",
    "render_unit_policy",
    "render_validation"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1"] },
    "deck_id": { "type": "string", "description": "Stable deck identifier or delivery package name." },
    "slide_no": { "type": "integer", "minimum": 1 },
    "page_id": { "type": "string", "description": "Optional stable page id, e.g. P07_dual_v_lifecycle." },
    "spec_level": { "type": "string", "enum": ["light", "full"] },
    "page_risk_level": { "type": "string", "enum": ["normal", "complex", "high_risk", "history_runoff"] },
    "trigger_reason": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "complex_layout",
          "high_text_density",
          "strict_chart_semantics",
          "right_insight_panel",
          "bottom_conclusion_sensitive",
          "multi_card_hierarchy",
          "architecture_or_lifecycle",
          "roadmap_or_timeline",
          "decision_closeout",
          "previous_render_runoff"
        ]
      }
    },
    "source_trace": {
      "type": "object",
      "required": ["deck_spec_ref", "page_design_ref"],
      "properties": {
        "deck_spec_ref": { "type": "string" },
        "page_design_ref": { "type": "string" },
        "page_copy_ref": { "type": "string" },
        "source_evidence_ref": { "type": "string" },
        "inherited_fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "derived_contract": {
      "type": "object",
      "description": "Fields inherited from deck_spec/page_design, not independently authored here.",
      "properties": {
        "title": { "type": "string" },
        "core_judgement": { "type": "string" },
        "layout_pattern": { "type": "string" },
        "chart_type": { "type": "string" },
        "chart_proof_goal": { "type": "string" },
        "chart_visual_boundary": { "type": "array", "items": { "type": "string" } },
        "bottom_conclusion": { "type": "string" },
        "right_insight_panel": { "type": "object" },
        "red_anchor": { "type": "object" },
        "card_hierarchy": { "type": "string" },
        "spacing_rule": { "type": "string" },
        "visual_simplification": { "type": "string" }
      }
    },
    "subtype": {
      "type": "object",
      "required": ["subtype_enum"],
      "properties": {
        "subtype_enum": {
          "type": "string",
          "enum": [
            "dual_v_lifecycle_architecture",
            "self_learning_digital_twin_architecture",
            "decision_closeout",
            "three_column_chain",
            "two_column_panel",
            "quadrant_matrix",
            "roadmap_timeline",
            "case_proof",
            "custom"
          ]
        },
        "custom_subtype_note": {
          "type": "string",
          "description": "Required only when subtype_enum=custom; explain why no known subtype fits."
        }
      }
    },
    "render_units": {
      "type": "array",
      "description": "Renderable page units with hierarchy, content binding, region intent and overflow policy.",
      "items": {
        "type": "object",
        "required": ["unit_id", "unit_type", "semantic_role", "content_source", "priority"],
        "properties": {
          "unit_id": { "type": "string" },
          "unit_type": {
            "type": "string",
            "enum": ["title", "subtitle", "card", "chart", "axis", "arrow", "timeline", "table", "icon_label", "right_insight", "bottom_conclusion", "footer", "source_note"]
          },
          "semantic_role": { "type": "string" },
          "content_source": {
            "type": "object",
            "properties": {
              "from": { "type": "string", "enum": ["deck_spec", "page_design", "page_copy", "source_evidence"] },
              "field": { "type": "string" },
              "no_new_content": { "type": "boolean" }
            }
          },
          "priority": { "type": "string", "enum": ["primary", "secondary", "tertiary", "supporting"] },
          "region_intent": { "type": "string" },
          "max_text_lines": { "type": "integer" },
          "overflow_action": { "type": "string", "enum": ["compress", "truncate_with_review", "split_unit", "manual_review"] },
          "visual_constraints": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "text_fit_policy": {
      "type": "object",
      "properties": {
        "title_max_lines": { "type": "integer" },
        "card_title_max_lines": { "type": "integer" },
        "card_body_max_lines": { "type": "integer" },
        "bottom_conclusion_max_lines": { "type": "integer" },
        "right_insight_max_items": { "type": "integer" },
        "compression_order": { "type": "array", "items": { "type": "string" } },
        "manual_review_threshold": { "type": "string" }
      }
    },
    "render_unit_policy": {
      "type": "object",
      "properties": {
        "red_anchor_budget": { "type": "string" },
        "primary_focus_count": { "type": "integer" },
        "card_hierarchy_rule": { "type": "string" },
        "bottom_bar_rule": { "type": "string" },
        "right_insight_rule": { "type": "string" },
        "spacing_rule": { "type": "string" },
        "forbidden_patterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "render_validation": {
      "type": "object",
      "required": ["must_pass", "manual_review_if"],
      "properties": {
        "must_pass": { "type": "array", "items": { "type": "string" } },
        "manual_review_if": { "type": "array", "items": { "type": "string" } },
        "expected_builder_behavior": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
